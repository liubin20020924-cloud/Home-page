# ============================================
# 云户科技网站 - 统一配置文件
# ============================================
# 使用说明:
# 1. 将此文件复制为 .env (不要提交 .env 到 Git)
# 2. 根据实际环境修改配置值
# 3. 所有配置项都有默认值，可根据需要调整
# ============================================

# ============================================
# Flask 基础配置
# ============================================
# Flask 安全密钥 (生产环境必须修改)
FLASK_SECRET_KEY=your-secret-key-here-change-in-production

# 调试模式 (生产环境设置为 False)
FLASK_DEBUG=False

# ============================================
# 服务器配置
# ============================================
# 服务器监听地址 (0.0.0.0 监听所有网卡)
FLASK_HOST=0.0.0.0

# 服务器端口
FLASK_PORT=5000

# 网站基础URL (用于生成链接)
SITE_URL=http://your-domain.com

# ============================================
# 数据库配置
# ============================================
# 数据库主机
DB_HOST=127.0.0.1

# 数据库端口
DB_PORT=3306

# 数据库用户名
DB_USER=root

# 数据库密码 (必须设置)
DB_PASSWORD=your-database-password

# 官网系统数据库名称
DB_NAME_HOME=clouddoors_db

# 知识库系统数据库名称
DB_NAME_KB=YHKB

# 工单系统数据库名称
DB_NAME_CASE=casedb

# ============================================
# 邮件配置 - 企业微信邮箱
# ============================================
# 邮件服务器 (企业微信邮箱: smtp.exmail.qq.com)
MAIL_SERVER=smtp.exmail.qq.com

# 邮件服务器端口 (企业微信邮箱 SSL: 465)
MAIL_PORT=465

# 是否使用 TLS (465 端口使用 SSL，设为 False)
MAIL_USE_TLS=False

# 邮件登录用户名
MAIL_USERNAME=your_email@company.com

# 邮件登录密码/授权码
MAIL_PASSWORD=your-email-password-or-authorization-code

# 默认发件人邮箱
MAIL_DEFAULT_SENDER=your_email@company.com

# 联系邮箱 (也是接收通知的邮箱)
CONTACT_EMAIL=your_email@company.com

# ============================================
# Trilium 配置 (知识库后端)
# ============================================
# Trilium 服务器 URL
TRILIUM_SERVER_URL=http://127.0.0.1:8080

# Trilium API Token (必须设置)
TRILIUM_TOKEN=your-trilium-api-token

# Trilium 服务器主机
TRILIUM_SERVER_HOST=127.0.0.1:8080

# Trilium 登录用户名 (可选)
TRILIUM_LOGIN_USERNAME=

# Trilium 登录密码 (可选)
TRILIUM_LOGIN_PASSWORD=

# ============================================
# 知识库系统配置
# ============================================
# 默认管理员密码 (生产环境必须修改)
DEFAULT_ADMIN_PASSWORD=your-strong-admin-password-here

# ============================================
# CORS 跨域配置
# ============================================
# 允许的跨域来源 (多个用逗号分隔，* 表示允许所有)
ALLOWED_ORIGINS=*

# ============================================
# Redis 配置 (可选)
# ============================================
# 是否启用 Redis
REDIS_ENABLED=False

# Redis 主机
REDIS_HOST=127.0.0.1

# Redis 端口
REDIS_PORT=6379

# Redis 数据库编号
REDIS_DB=0

# Redis 密码
REDIS_PASSWORD=

# ============================================
# CDN 配置 (可选)
# ============================================
# 是否启用 CDN
CDN_ENABLED=False

# CDN 域名
CDN_DOMAIN=

# CDN 协议
CDN_PROTOCOL=https

# ============================================
# 图片优化配置
# ============================================
# 图片质量 (1-100)
IMAGE_QUALITY=80

# 是否启用 WebP 格式
IMAGE_ENABLE_WEBP=True

# 是否自动压缩
IMAGE_AUTO_COMPRESS=True

# 图片缓存时间 (秒，默认 7 天)
IMAGE_CACHE_TTL=604800

# ============================================
# 缓存配置
# ============================================
# 缓存类型 (redis, simple, filesystem)
CACHE_TYPE=simple

# 默认缓存超时时间 (秒，默认 7 天)
CACHE_DEFAULT_TIMEOUT=604800

# 缓存键前缀
CACHE_KEY_PREFIX=yundour_

# ============================================
# 日志配置
# ============================================
# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/app.log

# 日志文件最大大小 (MB)
LOG_MAX_BYTES=10

# 日志文件备份数量
LOG_BACKUP_COUNT=5

# ============================================
# 数据库连接池配置 (高级配置)
# ============================================
# 最大连接数
DB_POOL_MAX_CONNECTIONS=20

# 最小缓存连接数
DB_POOL_MIN_CACHED=5

# 最大缓存连接数
DB_POOL_MAX_CACHED=10

# 最大共享连接数
DB_POOL_MAX_SHARED=5

# ============================================
# Session 配置 (高级配置)
# ============================================
# Session 超时时间 (秒，默认 3 小时)
SESSION_TIMEOUT=10800

# Session Cookie 名称
SESSION_COOKIE_NAME=cloud_doors_session

# Session SameSite 策略 (Lax, Strict, None)
SESSION_COOKIE_SAMESITE=Lax

# ============================================
# 文件上传配置 (高级配置)
# ============================================
# 最大上传文件大小 (字节，默认 16MB)
MAX_CONTENT_LENGTH=16777216

# ============================================
# 静态文件配置 (高级配置)
# ============================================
# 静态文件缓存时间 (秒，默认 1 小时)
STATIC_CACHE_TIME=3600
